# @currentEnv=$VARLOCK_ENV @defaultRequired=infer @defaultSensitive=inferFromPrefix(PUBLIC_)
# @generateTypes(lang=ts, path=src/env.d.ts)
# @plugin(@varlock/1password-plugin)
# @initOp(token=$OP_TOKEN, allowAppAuth=forEnv(development))
# ---

# Service account token for CI/prod; locally falls back to desktop app auth.
# @type=opServiceAccountToken @sensitive @optional
OP_TOKEN=

# ── GitHub OAuth ────────────────────────────────────────────────
# @required
GITHUB_CLIENT_ID=op(op://ENV/kyrre.dev/GITHUB_CLIENT_ID)
# @required
GITHUB_CLIENT_SECRET=op(op://ENV/kyrre.dev/GITHUB_CLIENT_SECRET)
# @required @sensitive=false
GITHUB_USERNAME=op(op://ENV/kyrre.dev/GITHUB_USERNAME)

# ── Services ────────────────────────────────────────────────────
# @required @type=string(startsWith=sk-)
OPENAI_API_KEY=op(op://ENV/kyrre.dev/OPENAI_API_KEY)
# @required
RESEND_API_KEY=op(op://ENV/kyrre.dev/RESEND_API_KEY)

# ── Cloudflare R2 ───────────────────────────────────────────────
# @required
R2_ACCOUNT_ID=op(op://ENV/kyrre.dev/R2_ACCOUNT_ID)
# @required
R2_ACCESS_KEY_ID=op(op://ENV/kyrre.dev/R2_ACCESS_KEY_ID)
# @required
R2_SECRET_ACCESS_KEY=op(op://ENV/kyrre.dev/R2_SECRET_ACCESS_KEY)
# @required @sensitive=false
R2_BUCKET_NAME=op(op://ENV/kyrre.dev/R2_BUCKET_NAME)

# ── Turso DB ────────────────────────────────────────────────────
# @required @type=url
TURSO_CONNECTION_URL=op(op://ENV/kyrre.dev/TURSO_CONNECTION_URL)
# @required
TURSO_AUTH_TOKEN=op(op://ENV/kyrre.dev/TURSO_AUTH_TOKEN)

# ── Sanity ──────────────────────────────────────────────────────
# @required
PUBLIC_SANITY_PROJECT_ID=op(op://ENV/kyrre.dev/PUBLIC_SANITY_PROJECT_ID)
# @required
PUBLIC_SANITY_DATASET=op(op://ENV/kyrre.dev/PUBLIC_SANITY_DATASET)
PUBLIC_SANITY_API_VERSION=op(op://ENV/kyrre.dev/PUBLIC_SANITY_API_VERSION)
# @type=url
PUBLIC_SANITY_STUDIO_URL=op(op://ENV/kyrre.dev/PUBLIC_SANITY_STUDIO_URL)
# @sensitive=false
SANITY_STUDIO_PROJECT_ID=op(op://ENV/kyrre.dev/SANITY_STUDIO_PROJECT_ID)
# @sensitive=false
SANITY_STUDIO_DATASET=op(op://ENV/kyrre.dev/SANITY_STUDIO_DATASET)
# @sensitive
SANITY_API_READ_TOKEN=op(op://ENV/kyrre.dev/SANITY_API_READ_TOKEN)

# ── Analytics ───────────────────────────────────────────────────
# @type=url
PUBLIC_PLAUSIBLE_SCRIPT_URL=op(op://ENV/kyrre.dev/PUBLIC_PLAUSIBLE_SCRIPT_URL)
PUBLIC_POSTHOG_API_KEY=op(op://ENV/kyrre.dev/PUBLIC_POSTHOG_API_KEY)
# @type=url
PUBLIC_POSTHOG_HOST=op(op://ENV/kyrre.dev/PUBLIC_POSTHOG_HOST)
PUBLIC_POSTHOG_PROJECT_ID=op(op://ENV/kyrre.dev/PUBLIC_POSTHOG_PROJECT_ID)

# ── reCAPTCHA ───────────────────────────────────────────────────
PUBLIC_RECAPCHA_SITE_KEY=op(op://ENV/kyrre.dev/PUBLIC_RECAPCHA_SITE_KEY)
# @sensitive
RECAPTCHA_SECRET_KEY=op(op://ENV/kyrre.dev/RECAPTCHA_SECRET_KEY)

# ── Realtime ────────────────────────────────────────────────────
# @required @type=url
PUBLIC_PARTYKIT_URL=op(op://ENV/kyrre.dev/PUBLIC_PARTYKIT_URL)
