		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rehype-slug": "^6.0.0",
		"rehype-unwrap-images": "^1.0.0",
		"remark-toc": "^9.0.0",
		"remark-unwrap-images": "^5.0.0",
